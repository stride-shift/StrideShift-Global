# Supabase — copy to .env and fill in from your Supabase dashboard
# Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: redirect to a custom path after sign-in (defaults to /admin)
# VITE_AUTH_REDIRECT_AFTER_SIGNIN=/admin

